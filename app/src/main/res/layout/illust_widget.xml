<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_illust_background"
    android:orientation="vertical"
    android:padding="14dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/widget_illust_frame">

        <ImageView
            android:id="@+id/widget_image"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop" />

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/widget_illust_overlay"
            android:contentDescription="@null" />

        <LinearLayout
            android:id="@+id/widget_empty_state"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="18dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/widget_empty_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:textColor="@color/widget_illust_on_surface"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/widget_empty_button"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/widget_illust_icon_chip"
                android:contentDescription="@null"
                android:padding="10dp"
                android:tint="@color/widget_illust_primary" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_content"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/widget_change"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/widget_illust_icon_chip"
                    android:contentDescription="@null"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_menu_edit"
                    android:tint="@color/widget_illust_primary" />

                <ImageView
                    android:id="@+id/widget_refresh"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/widget_illust_icon_chip"
                    android:contentDescription="@null"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_popup_sync"
                    android:tint="@color/widget_illust_on_surface" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:gravity="bottom"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/widget_title_plate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/widget_illust_title_plate"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/widget_title"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="2"
                        android:paddingHorizontal="12dp"
                        android:paddingTop="10dp"
                        android:paddingBottom="12dp"
                        android:textColor="@color/widget_illust_on_surface"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
